<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.TicketApp.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/on_background</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.TicketApp.Subtitle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/on_surface_muted</item>
    </style>

    <style name="Widget.TicketApp.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="Widget.TicketApp.CardList" parent="Widget.TicketApp.Card">
        <item name="cardCornerRadius">@dimen/card_corner_sm</item>
    </style>

    <!-- Login fields: avoid helper text strip that can feel like an extra popup on focus. -->
    <style name="Widget.TicketApp.TextInputLayout.Login" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="helperTextEnabled">false</item>
    </style>
</resources>
